!data/documents/pgvector_intro.txt

# Cachés de pruebas y linters
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Cachés de modelos descargados localmente (sentence-transformers)
.cache/

# Archivos del editor / SO
.vscode/
.idea/
Thumbs.db
.DS_Store

# Estado local de herramientas de asistencia (no forma parte del proyecto)
.claude/
