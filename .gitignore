# Entornos virtuales
.venv/
venv/
env/

# Bytecode y cachés de Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/

# Variables de entorno y secretos
.env
.env.*
!.env.example

# Datos de prueba de PostgreSQL (si se usa un volumen bind local)
docker/pgdata/

# Documentos ingeridos por el usuario (se conserva el ejemplo versionado)
data/documents/*
