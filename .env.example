# Proveedor del LLM de generación: "anthropic" (Claude) o "gemini" (Google)
LLM_PROVIDER=anthropic

# Modelo del proveedor seleccionado.
#   anthropic -> claude-opus-4-8
#   gemini    -> gemini-flash-latest (alias estable; algunos modelos fechados
#                como gemini-2.5-flash ya no admiten claves nuevas. Usa
#                python -c "import google.generativeai as genai; genai.configure(
#                api_key='TU_CLAVE'); [print(m.name) for m in genai.list_models()]"
#                para ver los modelos habilitados en tu clave)
LLM_MODEL=claude-opus-4-8

# Clave de API de Anthropic (https://console.anthropic.com/) — requerida solo si LLM_PROVIDER=anthropic. NUNCA subir el valor real.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave de API de Google AI Studio (https://aistudio.google.com/apikey) — requerida solo si LLM_PROVIDER=gemini. NUNCA subir el valor real.
GOOGLE_API_KEY=

# Proveedor de embeddings: "huggingface" (local, por defecto) u "openai"
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Cadena de conexión a PostgreSQL con PGVector (ver Fase 3 para el contenedor Docker)
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_db

# Nombre de la colección/tabla lógica dentro de PGVector
PGVECTOR_COLLECTION=documents

# Parámetros de fragmentación (chunking) de documentos
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Número de fragmentos a recuperar por consulta
RETRIEVAL_TOP_K=4
